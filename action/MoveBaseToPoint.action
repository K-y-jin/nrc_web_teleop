# MoveBaseToPoint takes in the scaled (u,v) coordinates of a click on the Wide-Angle camera.
# It then move the robot to the selected location, giving feedback on the way.

# These should be in the range [0.0, 1.0]
float64 scaled_u
float64 scaled_v

---
# Result

uint8 STATUS_SUCCESS=0
uint8 STATUS_FAILURE=1
uint8 STATUS_CANCELLED = 2
uint8 STATUS_TIMEOUT = 3
uint8 STATUS_GOAL_NOT_REACHABLE = 4
uint8 STATUS_DEPROJECTION_FAILURE = 5
uint8 STATUS_STRETCH_DRIVER_FAILURE = 6
uint8 STATUS_JOINTS_IN_COLLISION = 7

uint8 status
---
# Feedback
# 클릭 마커 위치(원래 클릭한 정규화 픽셀).
float32 new_scaled_u
float32 new_scaled_v
# false면 UI에서 클릭 마커를 숨긴다. (B) 액션 진행 중에는 false.
bool show_click_marker
# DEFAULT_ARM_LENGTH_MM 만큼 base 쪽으로 당긴 base 정지 예상 위치.
# 회전 후에는 base rotation이 반영된 위치로 갱신, translation 중에는
# 진행률에 따라 base(=DEPTH_REF)에 가까워지는 위치로 갱신된다.
float32 new_stop_scaled_u
float32 new_stop_scaled_v
# false면 UI에서 stop 마커를 숨긴다. 회전 진행 중에는 false, 회전 완료 후
# translation 진행 중에는 true.
bool show_stop_marker
builtin_interfaces/Duration elapsed_time